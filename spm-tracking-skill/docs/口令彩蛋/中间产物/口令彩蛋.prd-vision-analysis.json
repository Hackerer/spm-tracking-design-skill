  "core_flow_steps": [
    {
      "step_name": "确认车型版本覆盖",
      "description": "需求需按 APP 端、HMI 端以及智能车载、量产车A版本等不同车型/版本确认覆盖范围与实现差异。",
      "evidence_files": [
        "1.png"
      ]
    },
    {
      "step_name": "APP端曝光口令能力",
      "description": "用户进入等待接驾页或行程中页面后，若命中教学规则则先展示口令教学动效；若未命中则直接展示口令常驻入口。教学动效受单用户频控、页面完整曝光和弹层打断恢复规则控制。",
      "evidence_files": [
        "2.png",
        "3.png"
      ]
    },
    {
      "step_name": "查看口令说明",
      "description": "用户点击行程卡片左上角的口令常驻入口后，在 APP 内拉起口令说明半弹层，查看今日口令、活动说明和奖品预告，并可通过右上角关闭按钮或点击弹层外区域收起。",
      "evidence_files": [
        "2.png",
        "3.png"
      ]
    },
    {
      "step_name": "HMI侧触发彩蛋",
      "description": "用户上车后，HMI 首页出现口令彩蛋入口挂件或悬浮入口；用户在首页或应用页面说出口令，或点击可点击入口后，触发彩蛋展现。",
      "evidence_files": [
        "2.png",
        "4.png",
        "6.png"
      ]
    },
    {
      "step_name": "展现彩蛋内容",
      "description": "彩蛋被触发后，系统展示全屏或中心弹层形式的彩蛋内容；该阶段存在播放、完播以及被首页、应用页、熄屏等场景打断的处理逻辑。",
      "evidence_files": [
        "4.png",
        "6.png",
        "11.png"
      ]
    },
    {
      "step_name": "请求并展示权益",
      "description": "行程开始后或彩蛋触发后，HMI 请求口令模块和权益模块，获取本次行程命中的权益信息，并在权益展现态中按页面层级或数字人层级展示最多三份权益，数量不足时按实际返回展示。",
      "evidence_files": [
        "2.png",
        "5.png",
        "7.png"
      ]
    },
    {
      "step_name": "用户选择并领取权益",
      "description": "用户在权益展现页从最多三份权益中三选一，可通过点击选择按钮或语音指定权益进行领取。领取后已选权益卡片放大并左移，其余权益消失。",
      "evidence_files": [
        "2.png",
        "5.png",
        "7.png"
      ]
    },
    {
      "step_name": "展示领取结果与后续承接",
      "description": "权益领取后，右侧根据权益类型展示对应二维码及引导文案，可能包含订单物流二维码、商品商详二维码、打车二维码，部分权益还支持跳转对应 APP 或服务。再次触发彩蛋时可直接进入已领取状态。",
      "evidence_files": [
        "5.png",
        "7.png"
      ]
    },
    {
      "step_name": "异常兜底与不可领取处理",
      "description": "当权益信息获取失败、未命中、超时或权益已发完不可领取时，系统展示统一兜底页面或不可领取提示文案。",
      "evidence_files": [
        "5.png",
        "7.png"
      ]
    },
    {
      "step_name": "后台完成口令与权益配置",
      "description": "运营侧在口令模块中注册口令描述、类型、动作、APP/HMI 素材、生效规则、车型和人群，并在权益模块中配置奖品、活动、发放规则；订单口令生成后结合车型、人群、订单信息进行口令匹配并执行关联 Action。",
      "evidence_files": [
        "2.png",
        "8.png",
        "9.png"
      ]
    },
    {
      "step_name": "推荐分发与数据统计",
      "description": "推荐系统将口令彩蛋内容分发至 APP 首页、推荐页、排行圈、行程结束页及 HMI 首页等入口；数据需求需统计入口曝光、弹层曝光、彩蛋播放、权益曝光/领取/核销、语音触发等指标，并支持按行程、成交或券类型拆分。",
      "evidence_files": [
        "10.png",
        "11.png"
      ]
    }
  ],
